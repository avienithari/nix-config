alias vim="nvim"
alias py="python3"
alias attach="tmux attach -d -t"

ff() {
    if [[ -n "$TMUX" ]]; then
        fastfetch -c ~/.config/fastfetch/tmux-conf.jsonc "$@"
    else
        fastfetch "$@"
    fi
}

ytd() {
    local mode="$1"
    shift

    case "$mode" in
        audio)
            command yt-dlp \
                --format "bestaudio" \
                -x \
                --audio-format flac \
                "$@"
            ;;
        video)
            command yt-dlp \
                --format "bestvideo[ext=mp4][vcodec^=avc]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
                --merge-output-format mp4 \
                --remux-video mp4 \
                "$@"
            ;;
        *)
            echo "Usage:\nytd audio <url>\nytd video <url>"
            return 1
            ;;
        esac
}

autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line

bindkey ' ' magic-space

export PATH=${PATH}:~/.config/scripts/
export PATH=${PATH}:~/go/bin/

export EDITOR="nvim"

bindkey -s ^f "sessionizer\n"
